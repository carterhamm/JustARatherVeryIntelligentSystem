#!/bin/bash
# JARVIS Voice Synthesis - Ultimate Quality Launcher
# Usage: ./jarvis "Your text here"

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
VENV_DIR="$SCRIPT_DIR/jarvis_venv"

# Check if venv exists
if [ ! -d "$VENV_DIR" ]; then
    echo "❌ Virtual environment not found!"
    echo "Run: cd jarvis_voice_training && source jarvis_venv/bin/activate"
    exit 1
fi

# Activate venv and run Ultimate version (16-bit/44.1kHz with gentle noise removal)
source "$VENV_DIR/bin/activate"
cd "$SCRIPT_DIR"
python3 synthesize_jarvis_ultimate.py "$@"
