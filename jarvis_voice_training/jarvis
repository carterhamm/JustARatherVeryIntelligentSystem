#!/bin/bash
# JARVIS Voice Synthesis - Fast Mode
# Uses background server for instant responses
# Usage: ./jarvis "Your text here"

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
VENV_PYTHON="$SCRIPT_DIR/jarvis_venv/bin/python3"

# Run client (will auto-start server if needed)
"$VENV_PYTHON" "$SCRIPT_DIR/jarvis_client.py" "$@"
