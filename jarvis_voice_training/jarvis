#!/bin/bash
# JARVIS Voice Synthesis - Original Quality
# Uses direct synthesis (slower but perfect quality)
# Usage: ./jarvis "Your text here"

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
VENV_DIR="$SCRIPT_DIR/jarvis_venv"

# Activate venv and run original script
source "$VENV_DIR/bin/activate"
cd "$SCRIPT_DIR"
python3 synthesize_jarvis_final.py "$@"
