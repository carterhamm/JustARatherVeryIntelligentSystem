# =============================================================================
# J.A.R.V.I.S. - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Application ---
APP_NAME="J.A.R.V.I.S."
DEBUG=false

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis_secret@localhost:5432/jarvis

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# --- Qdrant (Cloud or local) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- ElevenLabs ---
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# --- Auth / Security ---
# IMPORTANT: Generate real values before deploying!
#   python3 -c "import secrets; print(secrets.token_hex(32))"          → JWT_SECRET_KEY
#   python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"  → AES_KEY
# If left blank, the app auto-generates ephemeral keys (fine for dev, NOT for production).
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
AES_KEY=

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- Google Gemini ---
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key

# --- Stark Protocol (local Gemma via LM Studio) ---
STARK_PROTOCOL_URL=http://localhost:1234/v1
STARK_PROTOCOL_API_KEY=lm-studio
STARK_PROTOCOL_ENABLED=false

# --- Cerebras (ultra-fast intent routing, ~2000 tok/s) ---
CEREBRAS_API_KEY=

# --- JARVIS Voice (local Coqui TTS) ---
JARVIS_VOICE_SERVER=/path/to/jarvis_voice_training
JARVIS_VOICE_ENABLED=false

# --- Default LLM Provider (claude | gemini | stark_protocol) ---
DEFAULT_LLM_PROVIDER=claude

# --- Google OAuth (Gmail + Calendar) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# --- Wolfram Alpha ---
WOLFRAM_APP_ID=your-wolfram-app-id

# --- Perplexity ---
PERPLEXITY_API_KEY=pplx-your-perplexity-api-key

# --- Alpha Vantage (Financial Data) ---
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# --- AviationStack (Flight Tracking) ---
AVIATIONSTACK_API_KEY=your-aviationstack-api-key

# --- Google Maps Platform ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Edamam (Nutrition & Recipes) ---
EDAMAM_APP_ID=your-edamam-app-id
EDAMAM_APP_KEY=your-edamam-app-key

# --- Web Search (configure at least one) ---
TAVILY_API_KEY=tvly-your-tavily-api-key
SERPAPI_API_KEY=your-serpapi-api-key
BRAVE_SEARCH_API_KEY=your-brave-search-api-key

# --- Weather (OpenWeatherMap) ---
WEATHER_API_KEY=your-openweathermap-api-key

# --- News (NewsAPI) ---
NEWS_API_KEY=your-newsapi-api-key

# --- Spotify ---
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REFRESH_TOKEN=your-spotify-refresh-token

# --- Google Drive (uses same OAuth as Gmail) ---
GOOGLE_DRIVE_ENABLED=false

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_ENABLED=false

# --- GitHub ---
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_ENABLED=false

# --- iMCP Bridge (remote macOS tools via Cloudflare tunnel) ---
IMCP_BRIDGE_URL=
IMCP_BRIDGE_KEY=

# --- Twilio (JARVIS phone number) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_USER_PHONE=+1XXXXXXXXXX

# --- Resend (outbound email from jarvis@malibupoint.dev) ---
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=JARVIS <jarvis@malibupoint.dev>

# --- Smart Home (Matter) ---
MATTER_CONTROLLER_URL=http://localhost:5580

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
